{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Warning",
      "Microsoft.AspNetCore.Http.Connections": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=highload_realtime;Username=postgres;Password=postgres"
  },
  "Performance": {
    "ThreadPool": {
      "MinWorkerThreads": 256,
      "MinCompletionPortThreads": 256
    },
    "Kestrel": {
      "HttpPort": 8080,
      "MaxConcurrentConnections": 200000,
      "MaxConcurrentUpgradedConnections": 200000,
      "KeepAliveSeconds": 30,
      "RequestHeadersTimeoutSeconds": 15,
      "SocketBacklog": 8192,
      "IoQueueCount": 0
    },
    "SignalR": {
      "KeepAliveIntervalSeconds": 10,
      "ClientTimeoutIntervalSeconds": 30,
      "HandshakeTimeoutSeconds": 10,
      "MaximumReceiveMessageSizeBytes": 65536,
      "StreamBufferCapacity": 32,
      "MaximumParallelInvocationsPerClient": 1,
      "EnableDetailedErrors": false
    },
    "Redis": {
      "Enabled": true,
      "Configuration": "localhost:6379,abortConnect=false,connectRetry=5",
      "ChannelPrefix": "highload-realtime",
      "AbortOnConnectFail": false,
      "ConnectRetry": 5,
      "ConnectTimeoutMs": 5000,
      "SyncTimeoutMs": 5000,
      "AsyncTimeoutMs": 5000,
      "KeepAliveSeconds": 15,
      "ExponentialRetryBaseMs": 2000
    },
    "Batching": {
      "QueueCapacity": 100000,
      "MaxBatchSize": 256,
      "FlushIntervalMs": 50,
      "DropThresholdRatio": 0.85
    },
    "HubGuard": {
      "TokenLimit": 1000,
      "TokensPerPeriod": 500,
      "ReplenishmentPeriodMs": 1000,
      "QueueLimit": 0
    }
  }
}
