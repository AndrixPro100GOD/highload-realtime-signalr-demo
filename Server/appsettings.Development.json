{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Performance": {
    "Redis": {
      "Enabled": false
    },
    "SignalR": {
      "EnableDetailedErrors": true
    },
    "HubGuard": {
      "TokenLimit": 2000,
      "TokensPerPeriod": 1000
    }
  }
}
